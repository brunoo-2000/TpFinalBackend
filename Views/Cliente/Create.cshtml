@model TpfinalBack.Models.Cliente

@{
    ViewData["Title"] = "Nuevo Cliente";
}

<h1>Nuevo Cliente</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <h5 class="mt-2 mb-3">Datos del cliente</h5>

            <div class="form-group mb-3">
                <label class="control-label">Nombre</label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">CUIT</label>
                <input asp-for="Cuit" class="form-control" />
                <span asp-validation-for="Cuit" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Teléfono</label>
                <input asp-for="Telefono" class="form-control" />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>

            <h5 class="mt-4 mb-3">Dirección (opcional)</h5>

            <div class="form-group mb-3">
                <label for="Calle" class="control-label">Calle</label>
                <input type="text" name="Calle" id="Calle" class="form-control" maxlength="150" />
            </div>

            <div class="form-group mb-3">
                <label for="Numero" class="control-label">Número</label>
                <input type="text" name="Numero" id="Numero" class="form-control" maxlength="10" />
            </div>

            <div class="form-group mb-3">
                <label for="Ciudad" class="control-label">Ciudad</label>
                <input type="text" name="Ciudad" id="Ciudad" class="form-control" maxlength="100" />
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Crear" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
