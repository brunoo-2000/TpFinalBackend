@model TpfinalBack.Models.Pedido

@{
    ViewData["Title"] = "Despacho";
    bool confirmado = Model.Confirmado;
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h1>Despacho #@Model.Id</h1>
    @if (confirmado)
    {
        <span class="badge bg-success fs-6">Confirmado</span>
    }
    else
    {
        <span class="badge bg-warning text-dark fs-6">Pendiente</span>
    }
</div>

<p class="text-muted mb-4">Cliente: <strong>@Model.Cliente?.Nombre</strong></p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!confirmado)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Agregar producto</h5>
            <form asp-action="AgregarProducto" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="pedidoId" value="@Model.Id" />
                <div class="col-md-6">
                    <label class="form-label">Producto</label>
                    <select name="productoId" id="selectProducto" class="form-select" required>
                        <option value="">-- Seleccionar producto --</option>
                        @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Productos)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Cantidad</label>
                    <input type="number" name="cantidad" class="form-control" min="1" value="1" required />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Agregar</button>
                </div>
            </form>
        </div>
    </div>
}

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Descripción</th>
            <th>Cantidad</th>
            <th>Costo Unitario</th>
            <th>Subtotal</th>
            @if (!confirmado)
            {
                <th></th>
            }
        </tr>
    </thead>
    <tbody>
        @if (Model.Detalles == null || !Model.Detalles.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">Sin productos cargados</td>
            </tr>
        }
        else
        {
            @foreach (var detalle in Model.Detalles)
            {
                <tr>
                    <td>@detalle.ProductoId</td>
                    <td>@detalle.Producto?.Descripcion</td>
                    <td>@detalle.Cantidad</td>
                    <td>$@detalle.CostoUnitario.ToString("N2")</td>
                    <td>$@detalle.SubTotal.ToString("N2")</td>
                    @if (!confirmado)
                    {
                        <td>
                            <form asp-action="EliminarDetalle" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="detalleId" value="@detalle.Id" />
                                <input type="hidden" name="pedidoId" value="@Model.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                            </form>
                        </td>
                    }
                </tr>
            }
        }
    </tbody>
</table>

<div class="card mt-3">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <p class="mb-1"><strong>Usuario:</strong> @Model.Usuario?.NombrePila</p>
                <p class="mb-1"><strong>Total de productos:</strong> @(Model.Detalles?.Sum(d => d.Cantidad) ?? 0)</p>
                <p class="mb-0"><strong>Monto total:</strong> $@((Model.Detalles?.Sum(d => d.SubTotal) ?? 0).ToString("N2"))</p>
            </div>
            @if (!confirmado)
            {
                <div class="col-md-6 d-flex align-items-center justify-content-end gap-2">
                    <form asp-action="Cancelar" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger btn-lg"
                                onclick="return confirm('¿Cancelar el despacho? Se perderán todos los productos cargados.')">
                            Cancelar Despacho
                        </button>
                    </form>
                    <form asp-action="Confirmar" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success btn-lg"
                                onclick="return confirm('¿Confirmás el pedido? Esta acción no se puede deshacer.')">
                            Confirmar Pedido
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-outline-secondary">Volver a Despachos</a>
</div>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container { width: 100% !important; }
        .select2-container .select2-selection--single { height: 38px; border: 1px solid #ced4da; border-radius: 0.375rem; }
        .select2-container--default .select2-selection--single .select2-selection__rendered { line-height: 36px; padding-left: 12px; }
        .select2-container--default .select2-selection--single .select2-selection__arrow { height: 36px; }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $('#selectProducto').select2({ placeholder: '-- Buscar producto --', allowClear: true });
    </script>
}
