@model TpfinalBack.Models.Producto
@{ ViewData["Title"] = "Eliminar Producto"; }

<h1>Eliminar Producto</h1>
<hr />

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <p class="mb-2"><strong>Descripción:</strong> @Model.Descripcion</p>
        <p class="mb-2"><strong>Costo Unitario:</strong> $@Model.CostoUnitario.ToString("N2")</p>
        <p class="mb-0"><strong>Stock:</strong> @Model.stock</p>
    </div>
</div>

@if (ViewBag.TieneDetalles == true)
{
    <div class="alert alert-warning mt-4">
        No se puede eliminar este producto porque está asociado a uno o más pedidos.
    </div>
    <a asp-action="Index" class="btn btn-secondary mt-2">Volver</a>
}
else
{
    <div class="alert alert-danger mt-4">¿Estás seguro que querés eliminar este producto?</div>
    <form asp-action="Delete" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Confirmar eliminación</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
    </form>
}
