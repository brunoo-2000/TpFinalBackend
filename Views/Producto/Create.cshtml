@model TpfinalBack.Models.Producto

@{
    ViewData["Title"] = "Nuevo Producto";
}

<h1>Nuevo Producto</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label class="control-label">Descripción</label>
                <input asp-for="Descripcion" class="form-control" />
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Costo Unitario</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="CostoUnitario" class="form-control" type="number" step="0.01" min="0.01" />
                </div>
                <span asp-validation-for="CostoUnitario" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Stock</label>
                <input asp-for="stock" class="form-control" type="number" min="0" />
                <span asp-validation-for="stock" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Crear" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
