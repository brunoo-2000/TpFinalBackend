@model TpfinalBack.Models.Usuario
@{ ViewData["Title"] = "Eliminar Usuario"; }

<h1>Eliminar Usuario</h1>
<hr />

<div class="alert alert-danger">¿Estás seguro que querés eliminar este usuario?</div>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <p class="mb-2"><strong>Username:</strong> @Model.Username</p>
        <p class="mb-0"><strong>Rol:</strong> <span class="badge @(Model.Rol == "Admin" ? "bg-danger" : "bg-secondary")">@Model.Rol</span></p>
    </div>
</div>

<form asp-action="Delete" class="mt-4">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirmar eliminación</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
</form>
