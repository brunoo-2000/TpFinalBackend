@model TpfinalBack.Models.Cliente

@{
    ViewData["Title"] = "Detalle Cliente";
}

<h1>@Model.Nombre</h1>
<hr />

<div class="row mb-4">
    <div class="col-md-6">
        <p class="mb-1"><strong>CUIT:</strong> @Model.Cuit</p>
        <p class="mb-0"><strong>Teléfono:</strong> @Model.Telefono</p>
    </div>
</div>

<h5>Direcciones</h5>
@if (Model.Direcciones == null || !Model.Direcciones.Any())
{
    <p class="text-muted">Este cliente no tiene direcciones registradas.</p>
}
else
{
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Calle</th>
                <th>Número</th>
                <th>Ciudad</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dir in Model.Direcciones)
            {
                <tr>
                    <td>@dir.Calle</td>
                    <td>@dir.Numero</td>
                    <td>@dir.Ciudad</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Volver</a>
</div>
