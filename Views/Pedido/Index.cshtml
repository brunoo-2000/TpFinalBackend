@model IEnumerable<TpfinalBack.Models.Pedido>

@{
    ViewData["Title"] = "Pedidos";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
}

<h1>Pedidos</h1>
<hr />

<form method="get" class="row g-2 mb-4">
    <div class="col-md-4">
        <select name="busqueda" id="selectUsuario" class="form-select">
            <option value="">-- Todos los usuarios --</option>
            @foreach (var u in (List<string>)ViewBag.Usuarios)
            {
                <option value="@u" selected="@(ViewBag.Busqueda == u ? "selected" : null)">@u</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Buscar</button>
        @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
        {
            <a asp-action="Index" class="btn btn-secondary ms-2">Limpiar</a>
        }
    </div>
</form>

@if (!Model.Any())
{
    @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
    {
        <div class="alert alert-info">El usuario <strong>@ViewBag.Busqueda</strong> no tiene pedidos confirmados.</div>
    }
    else
    {
        <div class="alert alert-info">No hay pedidos confirmados.</div>
    }
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Usuario</th>
                <th>Monto Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in Model)
            {
                <tr>
                    <td>@pedido.Id</td>
                    <td>@pedido.fechaDespacho.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@pedido.Cliente?.Nombre</td>
                    <td>@pedido.Usuario?.Username</td>
                    <td>$@pedido.MontoTotal.ToString("N2")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@pedido.Id" class="btn btn-sm btn-outline-primary">Ver detalle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $('#selectUsuario').select2({
            theme: 'bootstrap-5',
            placeholder: 'Buscar usuario...',
            allowClear: true,
            width: '100%'
        });
    </script>
}
