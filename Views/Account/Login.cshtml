@model TpfinalBack.DTOs.LoginDto
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = null;
}


<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión - Vivum</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/login.css"/>
</head>
<body class="d-flex align-items-center justify-content-center vh-100">

    <div class="card shadow" style="max-width: 400px; width: 100%;">
        <div class="card-body p-4">
            <img src="~/images/logo.png" alt="Logo" class="mb-4 mx-auto d-block" style="max-width: 150px;"/>
            
            <form asp-controller="Account" asp-action="Login" method="post">
                
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 font-weight-bold"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label">Usuario</label>
                    <input asp-for="Username" class="form-control" placeholder="Ingrese su usuario" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Contraseña</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Ingrese su contraseña" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 ">Ingresar</button>
            </form>
        </div>
    </div>

</body>
</html>