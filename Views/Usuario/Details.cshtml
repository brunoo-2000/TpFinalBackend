@model TpfinalBack.Models.Usuario
@{ ViewData["Title"] = "Detalle Usuario"; }

<h1>@Model.Username</h1>
<hr />

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <p class="mb-2"><strong>Username:</strong> @Model.Username</p>
        <p class="mb-0"><strong>Rol:</strong> <span class="badge @(Model.Rol == "Admin" ? "bg-danger" : "bg-secondary")">@Model.Rol</span></p>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Volver</a>
</div>
