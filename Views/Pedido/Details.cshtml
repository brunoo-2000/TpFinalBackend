@model TpfinalBack.Models.Pedido

@{
    ViewData["Title"] = "Detalle del Pedido";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h1>Pedido #@Model.Id</h1>
    <span class="badge bg-success fs-6">Confirmado</span>
</div>
<hr />

<div class="row mb-4">
    <div class="col-md-6">
        <p class="mb-1"><strong>Cliente:</strong> @Model.Cliente?.Nombre</p>
        <p class="mb-1"><strong>Usuario:</strong> @Model.Usuario?.Username</p>
        <p class="mb-0"><strong>Fecha:</strong> @Model.fechaDespacho.ToString("dd/MM/yyyy HH:mm")</p>
    </div>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Descripción</th>
            <th>Cantidad</th>
            <th>Costo Unitario</th>
            <th>Subtotal</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Detalles == null || !Model.Detalles.Any())
        {
            <tr>
                <td colspan="5" class="text-center text-muted">Sin productos</td>
            </tr>
        }
        else
        {
            @foreach (var detalle in Model.Detalles)
            {
                <tr>
                    <td>@detalle.ProductoId</td>
                    <td>@detalle.Producto?.Descripcion</td>
                    <td>@detalle.Cantidad</td>
                    <td>$@detalle.CostoUnitario.ToString("N2")</td>
                    <td>$@detalle.SubTotal.ToString("N2")</td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="card mt-3">
    <div class="card-body">
        <p class="mb-1"><strong>Total de productos:</strong> @(Model.Detalles?.Sum(d => d.Cantidad) ?? 0)</p>
        <p class="mb-0"><strong>Monto total:</strong> $@Model.MontoTotal.ToString("N2")</p>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Volver a Pedidos</a>
</div>
