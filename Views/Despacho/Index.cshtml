@model IEnumerable<TpfinalBack.Models.Pedido>

@{
    ViewData["Title"] = "Despachos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Despachos</h1>
    <a asp-action="Nuevo" class="btn btn-primary">+ Nuevo Despacho</a>
</div>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">No hay despachos pendientes.</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Usuario</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in Model)
            {
                <tr>
                    <td>@pedido.Id</td>
                    <td>@pedido.fechaDespacho.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@pedido.Cliente?.Nombre</td>
                    <td>@pedido.Usuario?.Username</td>
                    <td class="text-end">
                        <a asp-action="Editar" asp-route-id="@pedido.Id" class="btn btn-sm btn-outline-primary">Continuar</a>
                        <form asp-action="Cancelar" method="post" class="d-inline ms-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@pedido.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('¿Cancelar el despacho #@pedido.Id?')">
                                Cancelar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
