@model IEnumerable<TpfinalBack.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Usuarios</h1>
    <a asp-action="Create" class="btn btn-primary">+ Nuevo Usuario</a>
</div>
<hr />

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Username</th>
            <th>Rol</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Username</td>
                <td>@item.Rol</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
