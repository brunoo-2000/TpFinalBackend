@model IEnumerable<TpfinalBack.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Clientes</h1>
    <a asp-action="Create" class="btn btn-primary">+ Nuevo Cliente</a>
</div>
<hr />

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>CUIT</th>
            <th>Teléfono</th>
            <th>Direcciones</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Cuit</td>
                <td>@item.Telefono</td>
                <td>
                    @{
                        var cant = item.Direcciones?.Count ?? 0;
                    }
                    @if (cant == 0)
                    {
                        <span class="text-muted">Sin direcciones</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@cant</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detalle</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
