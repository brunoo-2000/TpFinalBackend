@model TpfinalBack.Models.Cliente
@{ ViewData["Title"] = "Eliminar Cliente"; }

<h1>Eliminar Cliente</h1>
<hr />

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <p class="mb-2"><strong>Nombre:</strong> @Model.Nombre</p>
        <p class="mb-2"><strong>CUIT:</strong> @Model.Cuit</p>
        <p class="mb-0"><strong>Teléfono:</strong> @Model.Telefono</p>
    </div>
</div>

@if (ViewBag.TienePedidos == true)
{
    <div class="alert alert-warning mt-4">
        No se puede eliminar este cliente porque tiene pedidos asociados.
    </div>
    <a asp-action="Index" class="btn btn-secondary mt-2">Volver</a>
}
else
{
    <div class="alert alert-danger mt-4">¿Estás seguro que querés eliminar este cliente? Se eliminarán también sus direcciones.</div>
    <form asp-action="Delete" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Confirmar eliminación</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
    </form>
}
