@{
    ViewData["Title"] = "Nuevo Despacho";
}

<h1>Nuevo Despacho</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Nuevo" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group mb-3">
                <label for="clienteId" class="control-label">Seleccioná un cliente</label>
                <select name="clienteId" id="clienteId" class="form-select" required>
                    <option value="">-- Seleccionar cliente --</option>
                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Clientes)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>
            </div>
            <div class="form-group mt-4">
                <input type="submit" value="Iniciar Despacho" class="btn btn-primary" />
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container { width: 100% !important; }
        .select2-container .select2-selection--single { height: 38px; border: 1px solid #ced4da; border-radius: 0.375rem; }
        .select2-container--default .select2-selection--single .select2-selection__rendered { line-height: 36px; padding-left: 12px; }
        .select2-container--default .select2-selection--single .select2-selection__arrow { height: 36px; }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $('#clienteId').select2({ placeholder: '-- Buscar cliente --', allowClear: true });
    </script>
}
